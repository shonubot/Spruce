<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.shonubot.Spruce</id>
  <name>Spruce</name>
  <summary>Reclaim disk space</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.shonubot">
    <name>Kavish Advani</name>
  </developer>

  <url type="homepage">https://github.com/shonubot/Spruce</url>
  <url type="bugtracker">https://github.com/shonubot/Spruce/issues</url>
  <url type="vcs-browser">https://github.com/shonubot/Spruce</url>

  <launchable type="desktop-id">io.github.shonubot.Spruce.desktop</launchable>
  <provides><binary>spruce</binary></provides>

  <categories>
    <category>Utility</category>
    <category>System</category>
  </categories>

  <branding>
    <color type="primary" scheme_preference="light">#81cf85</color>
    <color type="primary" scheme_preference="dark">#60d267</color>
  </branding>

<description>
  <p>Spruce is a lightweight cache cleaner and system maintenance tool designed for GNU/Linux. It helps keep your system fresh by clearing unneeded caches, logs, and temporary files in a clean, Adwaita-based GTK interface.</p>
  <ul>
    <li>Scan common cache locations</li>
    <li>Detect unused Flatpak runtimes and data</li>
    <li>Preview exactly what will be removed</li>
    <li>Clean with a single click</li>
  </ul>
</description>


  <releases>
     <release version="0.1.8" date="2026-2-2">
      <description><p>Fixed a UnboundLocalError.</p></description>
    </release>
     <release version="0.1.7" date="2026-1-31">
      <description><p>Added an "About" window and moved the "What's hidden button?" to a small button on the top of the unused packages list.</p></description>
    </release>
     <release version="0.1.6" date="2025-12-30">
      <description><p>Improved error handling when clearing unused packages, added a mention of freed space after removing a unused package or clearing caches and updated the window subtitle.</p></description>
    </release>
    <release version="0.1.5" date="2025-12-20">
      <description><p>Fixed a issue where the unused packages preview would not show up correctly when English is not the default language and improved the pie chart labels.</p></description>
    </release>
    <release version="0.1.4" date="2025-12-13">
      <description><p>Fixed a visual gap between the shaft and handle in the app icon. Fixed a GTK critical warning that occurred during cache cleanup and updated the application to the GNOME 49 runtime.</p></description>
    </release>
    <release version="0.1.3" date="2025-11-30">
      <description><p>Added confirmation and progress alerts to package removal and disabled auto-toggle for trash bin cleanup.</p></description>
    </release>
    <release version="0.1.2" date="2025-11-23">
      <description><p>Added Trash bin cleanup.</p></description>
    </release>
    <release version="0.1.1" date="2025-11-13">
      <description><p>Updated app icon and screenshots to follow Flathub quality guidelines.</p></description>
    </release>
    <release version="0.1.0" date="2025-09-01">
      <description><p>Initial release.</p></description>
    </release>
  </releases>

